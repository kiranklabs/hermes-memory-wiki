# Hermes Memory Wiki — Environment Configuration
# Copy this file to .env and adjust values as required.

# Path to Hermes state.db (default: ~/.hermes/state.db)
# Only change this if your Hermes state.db is in a non-standard location
# HERMES_STATE_DB=/path/to/your/state.db

# Wiki server port (default: 9876)
# Change if port 9876 is already in use
# PORT=9876
